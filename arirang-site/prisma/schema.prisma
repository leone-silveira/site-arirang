generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  student   Student?
}

model Student {
  id        String   @id @default(cuid())
  userId    String   @unique
  serie     String?
  turno     String?
  status    String?

  user User @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  STUDENT
}